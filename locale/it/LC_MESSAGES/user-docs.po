#: ../advanced/search.rst:1
msgid ""
"state.name:(closed OR open) AND (priority.name:\"2 normal\" OR "
"tags:feedback) AND !(*Zammad*)"
msgstr ""
"state.name:(chiuso OR aperto) AND (priority.name:\"2 normale\" OR "
"tags:feedback) AND !(*Zammad*)"

#: ../advanced/search.rst:1
msgid ""
"This gets the same result as above, expect that we don't want the ticket to "
"contain anything matching to \"Zammad\""
msgstr ""
"Questo ottiene lo stesso risultato di sopra, ma non vogliamo che il ticket "
"contenga nulla che corrisponda a \"Zammad\""

