#: ../advanced/search.rst:1
msgid ""
"state.name:(closed OR open) AND (priority.name:\"2 normal\" OR tags:feedback)"
msgstr ""
"state.name:(closed OR open) AND (priority.name:\"2 normal\" OR tags:feedback)"

#: ../advanced/search.rst:1
msgid ""
"Show every ticket that state is either closed or open and has priority "
